# Supabase (self-hosted, supabase.siller.io)
SUPABASE_URL=https://supabase.siller.io
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# hockeydata-API (public DEB key, referer-locked to deb-online.live)
HOCKEYDATA_API_KEY=3c5a99d835fcb70156d40cd60d03f350
HOCKEYDATA_REFERER=deb-online.live
HOCKEYDATA_BASE_URL=https://api.hockeydata.net
HOCKEYDATA_RATE_LIMIT_SEC=2.5
HOCKEYDATA_RATE_JITTER_SEC=0.5

# DGX LLM-Inference (pgxapi.siller.io)
DGX_BASE_URL=https://pgxapi.siller.io/v1
DGX_API_KEY=
DGX_CHAT_MODEL=gemma-4-31B
DGX_EMBED_MODEL=nomic-embed-text
DGX_EMBED_DIM=768

