# Streamlit Cloud → Settings → Secrets → diesen Inhalt einfügen.
# NIE diese Datei mit echten Werten committen!

# === Shared-Password fürs UI (Team-Zugriff) ===
app_password = "REPLACE_ME"

[default]
# === Supabase ===
SUPABASE_URL = "https://supabase.siller.io"
SUPABASE_SERVICE_ROLE_KEY = "REPLACE_ME"
DATABASE_URL = "postgresql://supabase_admin:REPLACE_ME@supabase.siller.io:6543/postgres"

# === LLM (Default OpenRouter — falls DGX gewählt: andere Werte) ===
DGX_BASE_URL = "https://openrouter.ai/api/v1"
DGX_API_KEY = "sk-or-v1-REPLACE_ME"
DGX_CHAT_MODEL = "deepseek/deepseek-v4-flash"
DGX_CHAT_FALLBACKS = "deepseek/deepseek-chat"
DGX_EMBED_MODEL = "text-embedding-3-small"
DGX_EMBED_DIM = 768

# === hockeydata (für ingestion, optional in UI) ===
HOCKEYDATA_API_KEY = "3c5a99d835fcb70156d40cd60d03f350"
HOCKEYDATA_REFERER = "deb-online.live"

